# =============================================================================
# Biometric AFIS — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust per your deployment:
#   cp .env.example .env

# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/fingerprint

# --- Compliance & Jurisdiction (ADR-007) ---
COMPLIANCE_STRATEGY=light           # light | extreme | gdpr
JURISDICTION_COUNTRY=República de Nicaragua
JURISDICTION_EXPERT_TITLE=Perito Forense
JURISDICTION_LEGAL_FRAMEWORK=Código Procesal Penal

# --- LLM Provider (ADR-006: Zero-Retention Doctrine) ---
# Tier 1 (Local / Air-Gapped): Ollama or vLLM
LLM_API_BASE=http://localhost:11434/v1
LLM_MODEL_NAME=llama3

# Tier 2 (Enterprise Cloud - requires BAA):
# LLM_API_BASE=https://<your-instance>.openai.azure.com/
# LLM_MODEL_NAME=gpt-4o
# LLM_API_KEY=your-key-here

# --- Storage Encryption (Client-Side) ---
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# STORAGE_ENCRYPTION_KEY=

# --- Frontend ---
VITE_API_URL=http://localhost:8000

# --- Performance ---
LOG_LEVEL=INFO
ENV=production
