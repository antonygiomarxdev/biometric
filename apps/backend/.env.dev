# Development configuration — local PostgreSQL, Qdrant, MinIO
# First start dependencies: docker compose -f docker-compose.dev.yml up -d

ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/fingerprint
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
LOG_LEVEL=DEBUG

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=biometric
MINIO_SECURE=false

# Disable NebulaGraph (not used in dev)
NEBULA_HOST=
